# ============================================================
# 環境変数（絶対にコミットしない）
# ============================================================
.env
.env.local
.env.production
.env.*.local
backend/.env

# ============================================================
# アップロード画像（キャラクター画像。各環境ごとに保存されるため除外）
# ============================================================
backend/app/static/character_images/*
!backend/app/static/character_images/.gitkeep
backend/app/static/reward_images/*
!backend/app/static/reward_images/.gitkeep

# ============================================================
# Python
# ============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.pytest_cache/

# ============================================================
# Node / Next.js
# ============================================================
node_modules/
frontend/.next/
frontend/out/
frontend/node_modules/

# ============================================================
# Docker / データ
# ============================================================
mysql_data/
mysql/backup/*.sql   # バックアップファイルは除外（.gitkeepは残す）

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# ドキュメント生成スクリプト（本番不要）
# ============================================================
create_doc*.js
YourTeacher_*.docx
plan/

# ============================================================
# IDE
# ============================================================
.vscode/
.idea/
*.swp
*.swo
