# ============================================================
# YourTeacher 環境変数設定ファイル
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env
# ============================================================

# ----- データベース -----
MYSQL_ROOT_PASSWORD=強いパスワードに変更してください
MYSQL_DATABASE=yourteacher
MYSQL_USER=yt_user
MYSQL_PASSWORD=強いパスワードに変更してください

# ----- バックエンド -----
DATABASE_URL=mysql+pymysql://yt_user:パスワード@db:3306/yourteacher
REDIS_URL=redis://redis:6379

# JWT署名キー（openssl rand -hex 32 で生成）
SECRET_KEY=ここに32文字以上のランダム文字列を入力してください

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Forms（GAS）からの受注Webhook認証シークレット（openssl rand -hex 24 などで生成）
WEBHOOK_SECRET=ここにWebhookシークレットを入力してください

# ----- CORS -----
# 本番ドメインに変更（カンマ区切りで複数指定可）
# 例: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ----- Swagger UI -----
# 本番環境では False に設定（API仕様を非公開にする）
DOCS_ENABLED=False

# ----- DM返信の下書き生成（Anthropic API） -----
# https://console.anthropic.com/ で発行したAPIキー
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- フロントエンド -----
# 本番ドメインに変更
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# ----- 決済（Stripe） -----
# 未設定のままでも動作する（決済関連エンドポイントは503を返し、従来のフォーム申し込みのみのフローになる）
# https://dashboard.stripe.com/apikeys で発行したシークレットキー
STRIPE_SECRET_KEY=
# https://dashboard.stripe.com/webhooks で発行したWebhook署名シークレット
STRIPE_WEBHOOK_SECRET=
# /apply（自作キャラ作成）の決済で使用するPrice ID（キャラ作成費）
# https://dashboard.stripe.com/products で対象商品を開き、「料金」欄に表示される price_... を設定する
STRIPE_PRICE_ID=
# 決済完了後のリダイレクト先（フロントエンドのベースURL）
FRONTEND_URL=http://localhost:3000

# ----- メール送信（Resend） -----
# https://resend.com/api-keys で発行したAPIキー
RESEND_API_KEY=
# 送信元メールアドレス（Resendでドメイン認証したアドレス）
RESEND_FROM_EMAIL=onboarding@resend.dev
